# backend/.env.example
# このファイルをコピーして .env を作成し、各値を設定してください
# cp .env.example .env

# PostgreSQL接続URL
# 形式: postgresql+psycopg2://<ユーザー名>:<パスワード>@<ホスト>:<ポート>/<DB名>
DATABASE_URL=postgresql+psycopg2://username:password@127.0.0.1:5432/dbname

# JWTトークン用の秘密鍵（長くランダムな文字列を設定してください）
SECRET_KEY=your-secret-key-here

# フロントエンドのURL（CORSで許可するURL）
FRONTEND_URL=http://localhost:5173
